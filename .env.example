# Resend – send kontaktskjema-leads på e-post
# Hent nøkkel på https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Hvem leadsene sendes til
LEAD_TO_EMAIL=post@strakstjenester.no

# Avsender. Må være et verifisert domene i Resend.
# Før domenet er verifisert kan du bruke onboarding@resend.dev
LEAD_FROM_EMAIL=nettside@strakstjenester.no

# Brukes til canonical URL / sitemap
NEXT_PUBLIC_SITE_URL=https://www.strakstjenester.no
